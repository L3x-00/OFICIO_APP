generator client {
  provider        = "prisma-client"
  output          = "../src/generated/client"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int              @id @default(autoincrement())
  email            String           @unique
  phone            String?          @unique
  passwordHash     String
  role             UserRole         @default(USUARIO)
  firstName        String
  lastName         String
  avatarUrl        String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  department       String?
  province         String?
  district         String?
  firebaseUid      String?          @unique
  isEmailVerified  Boolean          @default(false)
  fcmToken         String?
  coins            Int              @default(0)
  /// true cuando el usuario ya consumió el mes de cortesía (ESTANDAR).
  /// Se marca al reactivar una cuenta soft-deleted — un re-registro NO
  /// vuelve a recibir el mes de gracia (anti freemium abuse).
  hasUsedTrial     Boolean          @default(false)
  /// Fecha de auto-eliminación (soft delete por el propio usuario).
  /// null = cuenta no eliminada. Distingue el soft-delete del usuario
  /// de un baneo del admin (que solo pone isActive=false sin deletedAt),
  /// para que un re-registro NO reactive una cuenta suspendida.
  deletedAt        DateTime?
  lastIp           String?
  lastLoginAt      DateTime?
  chatsAsClient    ChatRoom[]       @relation("ClientChats")
  redemptions      CoinRedemption[]
  favorites        Favorite[]
  offerReports     OfferReport[]
  otpCodes         OtpCode[]
  platformIssues   PlatformIssue[]
  providerReports  ProviderReport[]
  providers        Provider[]
  recommendations  Recommendation[]
  referralCode     ReferralCode?
  referralReceived Referral?        @relation("ReferralInvited")
  referralsSent    Referral[]       @relation("ReferralInviter")
  refreshTokens    RefreshToken[]
  reviewReplies    ReviewReply[]
  reviews          Review[]
  serviceRequests  ServiceRequest[]
  penalty          UserPenalty?
  aiMemory         AiUserMemory?

  @@index([role, isActive])
  @@index([department, province])
  @@map("users")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_codes")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Locality {
  id              Int            @id @default(autoincrement())
  name            String
  department      String
  country         String         @default("Perú")
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  district        String?
  province        String?
  source          LocalitySource @default(SEED)
  department_norm String?
  province_norm   String?
  district_norm   String?
  providers       Provider[]

  @@index([department, province, district])
  @@index([source])
  @@index([department_norm, province_norm, district_norm], map: "localities_norm_active_idx", where: raw("(\"isActive\" = true)"))
  @@map("localities")
}

model Category {
  id                  Int                 @id @default(autoincrement())
  name                String
  slug                String              @unique
  iconUrl             String?
  parentId            Int?
  isActive            Boolean             @default(true)
  forType             String?
  parent              Category?           @relation("SubCategories", fields: [parentId], references: [id])
  children            Category[]          @relation("SubCategories")
  offerPostCategories OfferPostCategory[]
  providerCategories  ProviderCategory[]
  serviceRequests     ServiceRequest[]

  @@map("categories")
}

/// Tabla de unión proveedor ↔ Especialidades (muchos a muchos).
/// Modelo "Multi-Especialidad con Sectores": un proveedor tiene varias
/// Especialidades (categorías hijas) — máximo según su plan — y marca
/// una como `isPrimary` (su oficio/negocio principal).
model ProviderCategory {
  id         Int      @id @default(autoincrement())
  providerId Int
  categoryId Int
  /// Especialidad principal del proveedor. Exactamente una por proveedor
  /// debería tener true; se muestra en grande en la tarjeta.
  isPrimary  Boolean  @default(false)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, categoryId])
  @@index([providerId])
  @@index([categoryId])
  @@map("provider_categories")
}

model Provider {
  id                   Int                       @id @default(autoincrement())
  userId               Int
  type                 ProviderType              @default(OFICIO)
  businessName         String
  description          String?
  phone                String
  whatsapp             String?
  address              String?
  latitude             Float?
  longitude            Float?
  scheduleJson         Json?
  availability         AvailabilityStatus        @default(DISPONIBLE)
  isVisible            Boolean                   @default(true)
  verificationStatus   VerificationStatus        @default(PENDIENTE)
  isVerified           Boolean                   @default(false)
  hasCleanRecord       Boolean                   @default(false)
  averageRating        Float                     @default(0)
  totalReviews         Int                       @default(0)
  localityId           Int
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  dni                  String?
  hasDelivery          Boolean                   @default(false)
  hasHomeService       Boolean                   @default(false)
  isTrusted            Boolean                   @default(false)
  nombreComercial      String?
  planPriority         Int                       @default(4)
  plenaCoordinacion    Boolean                   @default(false)
  razonSocial          String?
  ruc                  String?
  totalRecommendations Int                       @default(0)
  trustStatus          TrustStatus               @default(NONE)
  facebook             String?
  instagram            String?
  linkedin             String?
  telegram             String?
  tiktok               String?
  twitterX             String?
  website              String?
  whatsappBiz          String?
  /// Toggles de privacidad — INDEPENDIENTES del plan. El proveedor decide
  /// qué exponer en su perfil público (seguridad = derecho, no privilegio).
  showPhone            Boolean                   @default(true)
  showWhatsapp         Boolean                   @default(true)
  showExactLocation    Boolean                   @default(true)
  slug                 String?                   @unique
  slugEditedAt         DateTime?
  location_geog        Unsupported("geography")?
  search_tsv           Unsupported("tsvector")?
  notifications        AdminNotification[]
  chatsAsProvider      ChatRoom[]                @relation("ProviderChats")
  favorites            Favorite[]
  offerPosts           OfferPost[]
  offers               Offer[]
  planRequests         PlanRequest[]
  analytics            ProviderAnalytic[]
  providerCategories   ProviderCategory[]
  images               ProviderImage[]
  reports              ProviderReport[]
  locality             Locality                  @relation(fields: [localityId], references: [id])
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations      Recommendation[]
  referralRewards      ReferralReward[]
  referralReceived     Referral?                 @relation("ReferralInvitedProvider")
  reviews              Review[]
  subscription         Subscription?
  trustValidations     TrustValidationRequest[]
  verificationDocs     VerificationDoc[]
  yapePayments         YapePayment[]
  aiMemory             AiProviderMemory?

  @@unique([userId, type])
  @@index([isVisible, verificationStatus])
  @@index([isVisible, verificationStatus, averageRating])
  @@index([isVisible, verificationStatus, localityId])
  @@index([type])
  @@index([localityId])
  @@index([businessName(ops: raw("gin_trgm_ops"))], map: "providers_businessname_trgm", type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], map: "providers_description_trgm", type: Gin, where: raw("(description IS NOT NULL)"))
  @@index([location_geog], map: "providers_location_geog_gist", type: Gist, where: raw("(location_geog IS NOT NULL)"))
  @@index([search_tsv], map: "providers_search_tsv_gin", type: Gin)
  @@map("providers")
}

model ProviderImage {
  id         Int      @id @default(autoincrement())
  providerId Int
  url        String
  isCover    Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_images")
}

model Subscription {
  id          Int                    @id @default(autoincrement())
  providerId  Int                    @unique
  plan        SubscriptionPlan       @default(GRATIS)
  status      SubscriptionStatus     @default(GRACIA)
  startDate   DateTime               @default(now())
  endDate     DateTime
  graceMonths Int                    @default(2)
  priceUSD    Float                  @default(0)
  updatedAt   DateTime               @default(now()) @updatedAt
  payments    Payment[]
  auditLog    SubscriptionAuditLog[]
  provider    Provider               @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model SubscriptionAuditLog {
  id             Int                @id @default(autoincrement())
  subscriptionId Int
  oldStatus      SubscriptionStatus
  newStatus      SubscriptionStatus
  oldPlan        SubscriptionPlan
  newPlan        SubscriptionPlan
  changedAt      DateTime           @default(now())
  changedBy      Int?
  subscription   Subscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([subscriptionId, changedAt])
  @@map("subscription_audit_log")
}

model Payment {
  id             Int           @id @default(autoincrement())
  subscriptionId Int
  amount         Float
  currency       String        @default("PEN")
  method         PaymentMethod
  reference      String?
  confirmedAt    DateTime?
  createdAt      DateTime      @default(now())
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PlanRequest {
  id         Int               @id @default(autoincrement())
  providerId Int
  plan       SubscriptionPlan
  status     PlanRequestStatus @default(PENDIENTE)
  reason     String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  provider   Provider          @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([status])
  @@index([providerId, status])
  @@map("plan_requests")
}

model Review {
  id                 Int           @id @default(autoincrement())
  providerId         Int
  userId             Int
  rating             Int
  comment            String?
  photoUrl           String?
  isVisible          Boolean       @default(true)
  /// Cómo se validó la interacción cliente-proveedor antes de la reseña:
  /// 'AUCTION' | 'CONTACT' | 'CHAT'. null en reseñas previas al sistema.
  verificationMethod String?
  createdAt          DateTime      @default(now())
  replies            ReviewReply[]
  provider           Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([providerId, isVisible])
  @@map("reviews")
}

model ReviewReply {
  id        Int      @id @default(autoincrement())
  reviewId  Int
  userId    Int
  content   String
  photoUrl  String?
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_replies")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  providerId Int
  createdAt  DateTime @default(now())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@map("favorites")
}

model VerificationDoc {
  id         Int                 @id @default(autoincrement())
  providerId Int
  docType    VerificationDocType
  fileUrl    String
  status     VerificationStatus  @default(PENDIENTE)
  reviewedAt DateTime?
  notes      String?
  provider   Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("verification_docs")
}

model ProviderAnalytic {
  id         Int           @id @default(autoincrement())
  providerId Int
  eventType  AnalyticEvent
  userId     Int?
  createdAt  DateTime      @default(now())
  provider   Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, eventType])
  @@index([providerId, eventType, createdAt])
  @@index([createdAt])
  @@map("provider_analytics")
}

model AdminNotification {
  id                Int       @id @default(autoincrement())
  /// Nullable: las notificaciones dirigidas a un usuario-cliente (sin
  /// perfil de proveedor) no tienen providerId — se ubican por targetUserId.
  providerId        Int?
  /// String libre (antes enum NotificationType): permite persistir
  /// cualquier tipo de notificación (chat, referidos, ofertas, etc.).
  type              String
  message           String
  isRead            Boolean   @default(false)
  sentAt            DateTime  @default(now())
  targetProfileType String?
  targetUserId      Int?
  title             String    @default("")
  provider          Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, isRead])
  @@index([targetUserId])
  @@map("admin_notifications")
}

model Recommendation {
  id         Int      @id @default(autoincrement())
  userId     Int
  providerId Int
  createdAt  DateTime @default(now())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@index([providerId])
  @@map("recommendations")
}

model ProviderReport {
  id          Int          @id @default(autoincrement())
  providerId  Int
  userId      Int
  reason      ReportReason
  description String?
  isReviewed  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@index([providerId])
  @@index([isReviewed])
  @@map("provider_reports")
}

model PlatformIssue {
  id          Int      @id @default(autoincrement())
  userId      Int
  description String
  isReviewed  Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isReviewed])
  @@map("platform_issues")
}

model TrustValidationRequest {
  id                Int         @id @default(autoincrement())
  providerId        Int
  status            TrustStatus @default(PENDING)
  dniNumber         String?
  dniFirstName      String?
  dniLastName       String?
  dniAddress        String?
  dniPhotoFrontUrl  String?
  dniPhotoBackUrl   String?
  selfieWithDniUrl  String?
  rucNumber         String?
  businessAddress   String?
  businessPhotoUrl  String?
  ownerDniPhotoUrl  String?
  rejectionReason   String?
  reviewedByAdminId Int?
  reviewedAt        DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  businessPhoto2Url String?
  provider          Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([providerId])
  @@map("trust_validation_requests")
}

model ServiceRequest {
  id             Int                       @id @default(autoincrement())
  userId         Int
  categoryId     Int
  description    String
  photoUrl       String?
  budgetMin      Float?
  budgetMax      Float?
  desiredDate    DateTime?
  latitude       Float?
  longitude      Float?
  department     String?
  province       String?
  district       String?
  status         ServiceRequestStatus      @default(OPEN)
  maxOffers      Int                       @default(5)
  notifyRadiusKm Float                     @default(5)
  expiresAt      DateTime
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  location_geog  Unsupported("geography")?
  offers         Offer[]
  category       Category                  @relation(fields: [categoryId], references: [id])
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([categoryId])
  @@index([status, categoryId, expiresAt])
  @@index([status, expiresAt])
  @@index([location_geog], map: "service_requests_location_geog_gist", type: Gist, where: raw("(location_geog IS NOT NULL)"))
  @@map("service_requests")
}

model Offer {
  id               Int            @id @default(autoincrement())
  serviceRequestId Int
  providerId       Int
  price            Float
  message          String
  status           OfferStatus    @default(PENDING)
  arrivedAt        DateTime?
  arrivedLat       Float?
  arrivedLng       Float?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  provider         Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@unique([serviceRequestId, providerId])
  @@index([serviceRequestId])
  @@index([providerId])
  @@index([serviceRequestId, status])
  @@map("offers")
}

model YapePayment {
  id                Int               @id @default(autoincrement())
  providerId        Int
  plan              SubscriptionPlan
  /// Monto OFICIAL del plan en soles, fijado SERVER-SIDE desde el catálogo
  /// (anti-tampering). Es el valor que usa la activación de la suscripción.
  amount            Float
  /// Monto que el usuario DECLARÓ en la app (puede diferir si intentó hacer
  /// trampa o si Yape le cobró comisión). Solo informativo para que el admin
  /// detecte discrepancias. NO se usa para activar el plan.
  uploadedAmount    Float?
  voucherUrl        String
  verificationCode  String
  note              String?
  status            YapePaymentStatus @default(PENDING)
  rejectionReason   String?
  reviewedByAdminId Int?
  reviewedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  provider          Provider          @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([status])
  @@map("yape_payments")
}

model UserPenalty {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  noPickCount  Int       @default(0)
  /// Veces que el PROVEEDOR canceló (retiró) una oferta. A partir de 10 no
  /// puede postular a nuevas solicitudes (sí puede verlas).
  offerCancelCount Int   @default(0)
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_penalties")
}

/// Código único personal de cada usuario para invitar a otros.
/// Se genera bajo demanda (8 caracteres alfanuméricos).
model ReferralCode {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  code              String   @unique
  totalInvites      Int      @default(0)
  successfulInvites Int      @default(0)
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("referral_codes")
}

/// Vincula un invitado con quien lo invitó. Se crea con status PENDING al
/// aplicar el código y pasa a APPROVED cuando el admin aprueba el perfil
/// del invitado (entonces se entregan las monedas).
model Referral {
  id                  Int            @id @default(autoincrement())
  inviterId           Int
  invitedUserId       Int            @unique
  invitedProviderId   Int?           @unique
  status              ReferralStatus @default(PENDING)
  coinsAwarded        Int            @default(0)
  invitedCoinsAwarded Int            @default(0)
  createdAt           DateTime       @default(now())
  approvedAt          DateTime?
  invitedProvider     Provider?      @relation("ReferralInvitedProvider", fields: [invitedProviderId], references: [id])
  invitedUser         User           @relation("ReferralInvited", fields: [invitedUserId], references: [id], onDelete: Cascade)
  inviter             User           @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([inviterId])
  @@index([status])
  @@map("referrals")
}

/// Servicios canjeables creados por el admin: un proveedor ofrece un
/// servicio que los usuarios pueden adquirir gastando monedas.
model ReferralReward {
  id          Int              @id @default(autoincrement())
  providerId  Int
  title       String
  description String
  coinsCost   Int
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  redemptions CoinRedemption[]
  provider    Provider         @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([providerId])
  @@map("referral_rewards")
}

/// Canje de monedas: o por un plan (ESTANDAR/PREMIUM) o por una recompensa.
model CoinRedemption {
  id         Int               @id @default(autoincrement())
  userId     Int
  rewardId   Int?
  plan       SubscriptionPlan?
  coinsSpent Int
  status     RedemptionStatus  @default(PENDING)
  createdAt  DateTime          @default(now())
  reward     ReferralReward?   @relation(fields: [rewardId], references: [id])
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("coin_redemptions")
}

model ChatRoom {
  id         Int           @id @default(autoincrement())
  clientId   Int
  providerId Int
  createdAt  DateTime      @default(now())
  messages   ChatMessage[]
  client     User          @relation("ClientChats", fields: [clientId], references: [id], onDelete: Cascade)
  provider   Provider      @relation("ProviderChats", fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([clientId, providerId])
  @@index([clientId, providerId])
  @@map("chat_rooms")
}

model ChatMessage {
  id         Int           @id @default(autoincrement())
  chatRoomId Int
  senderId   Int
  content    String
  status     MessageStatus @default(SENT)
  createdAt  DateTime      @default(now())
  chatRoom   ChatRoom      @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([chatRoomId, createdAt])
  @@map("chat_messages")
}

/// Límites por plan: GRATIS=1 activa/12h, ESTANDAR=4/24h, PREMIUM=8/72h
model OfferPost {
  id          Int                 @id @default(autoincrement())
  providerId  Int
  title       String
  description String
  price       Float?
  photoUrl    String?
  expiresAt   DateTime
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  categories  OfferPostCategory[]
  provider    Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  reports     OfferReport[]

  @@index([providerId, isActive])
  @@index([isActive, expiresAt])
  @@map("offer_posts")
}

/// Categorías asignadas a una oferta (heredadas de las categorías del proveedor)
model OfferPostCategory {
  id          Int       @id @default(autoincrement())
  offerPostId Int
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  offerPost   OfferPost @relation(fields: [offerPostId], references: [id], onDelete: Cascade)

  @@unique([offerPostId, categoryId])
  @@index([offerPostId])
  @@index([categoryId])
  @@map("offer_post_categories")
}

/// Reportes de clientes sobre ofertas inapropiadas
model OfferReport {
  id          Int               @id @default(autoincrement())
  offerPostId Int
  reporterId  Int
  reason      OfferReportReason
  createdAt   DateTime          @default(now())
  isResolved  Boolean           @default(false)
  offerPost   OfferPost         @relation(fields: [offerPostId], references: [id], onDelete: Cascade)
  reporter    User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([offerPostId, reporterId])
  @@index([offerPostId])
  @@index([isResolved])
  @@map("offer_reports")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// Knowledge Base dinámica del asistente IA "Ofi" (Fase 2). Cada fila
/// es un "tema" (topic) con contenido JSON estructurado que se inyecta
/// en el system prompt. Editable sin redeploy. `createdBy` es el userId
/// del admin que la creó (Int? plano — sin relación FK para mantener el
/// módulo IA desacoplado del resto del esquema).
model AiKnowledgeEntry {
  id        Int      @id @default(autoincrement())
  topic     String   @unique
  content   Json
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdBy Int?
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("ai_knowledge_entries")
}

/// Conversación con el asistente IA "Ofi" (Fase 4). `userId` es Int plano
/// (sin FK a User) para mantener el módulo IA desacoplado. Guarda la
/// versión de prompt activa al crearse (regla 8) y sus mensajes en
/// cascada. Política de retención: se purga > 90 días (AiRetentionService).
model AiConversation {
  id            Int         @id @default(autoincrement())
  userId        Int
  promptVersion String      @default("v1")
  messages      AiMessage[]
  createdAt     DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ai_conversations")
}

/// Mensaje individual de una conversación con "Ofi" (Fase 4). Persiste
/// metadata de observabilidad: IP/UA del request, latencia, tokens
/// consumidos y banderas de moderación (flagged + moderationPass).
model AiMessage {
  id             Int            @id @default(autoincrement())
  conversationId Int
  /// 'user' | 'model'.
  role           String
  content        String
  ipAddress      String?
  userAgent      String?
  responseTimeMs Int?
  tokensUsed     Int?
  flagged        Boolean        @default(false)
  moderationPass Boolean        @default(true)
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([createdAt])
  @@map("ai_messages")
}

/// Memoria persistente del CLIENTE para "Ofi" — continuidad + menos tokens.
/// PEQUEÑA y acotada: NO guarda transcripciones, solo señales resumidas que
/// se inyectan compactas en el system prompt para no repreguntar y reducir
/// tool calls. 1 fila por usuario; se actualiza best-effort tras cada turno.
model AiUserMemory {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  /// Rubros buscados recientemente (cap 5, más reciente primero).
  searchCategories  String[] @default([])
  /// Proveedores surgidos/visitados en el chat (cap 8, más reciente primero).
  recentProviderIds Int[]    @default([])
  /// Última intención: 'search' | 'faq' | 'financial' | 'other'.
  lastIntent        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_user_memories")
}

/// Memoria persistente del PROVEEDOR para "Ofi". 1 fila por proveedor.
model AiProviderMemory {
  id              Int      @id @default(autoincrement())
  providerId      Int      @unique
  /// Categorías principales del perfil (cap 5).
  mainCategories  String[] @default([])
  /// Snapshot compacto de métricas: { rating, reviews, plan }.
  metricsSnapshot Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("ai_provider_memories")
}

