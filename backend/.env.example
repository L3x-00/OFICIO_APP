# ─────────────────────────────────────────────────────────────────────────────
# OficioApp Backend — Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://usuario:password@localhost:5432/oficio_db?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET="cambiar_por_secreto_aleatorio_min_64_chars"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="cambiar_por_otro_secreto_aleatorio_min_64_chars"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: localhost / Upstash: tu-endpoint.upstash.io
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
# Poner "true" si el proveedor requiere TLS (ej: Upstash en producción)
REDIS_TLS="false"

# ── Almacenamiento S3-compatible (MinIO / Cloudflare R2 / Backblaze B2) ───────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9001
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY=2b8c1ab623fa9ee4edab69702ea9ccdb
MINIO_SECRET_KEY=607632ba3800a647d5f9050e257770531d9cf04accff5330ab4b270ce0925149
MINIO_BUCKET_NAME="oficio-bucket"
# URL pública base para acceder a los archivos (Cloudflare R2 custom domain o r2.dev URL)
# Ejemplo R2: https://pub-xxxxxxxxxxxx.r2.dev
MINIO_PUBLIC_URL=""

# ── Email — Resend (resend.com) ───────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@tudominio.com"

# ── Firebase Admin — Login social ─────────────────────────────────────────────
# Opción A: JSON del Service Account como string (base64 o plano)
SERVICE_ACCOUNT_JSON=""
# Opción B: ruta al archivo JSON descargado de Firebase Console
# GOOGLE_APPLICATION_CREDENTIALS="/ruta/serviceAccountKey.json"

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
# URL pública del backend (usada para generar URLs de imágenes en BD)
API_BASE_URL="https://tu-app.onrender.com"

# ── CORS — orígenes permitidos en producción (separados por coma) ─────────────
# Ejemplo: https://admin.tudominio.com,https://tudominio.com
ALLOWED_ORIGINS="https://admin.tudominio.com"

# ── Sentry — Monitoreo de errores (sentry.io) ────────────────────────────────
# Dejar vacío para deshabilitar Sentry
SENTRY_DSN=""
