# ═══════════════════════════════════════════════════════════════
# Servi (Servi) — Backend NestJS · .env template
# ═══════════════════════════════════════════════════════════════
# Copiá este archivo como `.env` (gitignored) y completá los valores.
# Para deploy en Render: setear cada variable en Settings → Environment.

# ── App ────────────────────────────────────────────────────────
NODE_ENV=development                          # 'production' en Render
PORT=3000

# URL pública del backend. En desarrollo local con dispositivo físico
# usar la IP LAN (ej http://192.168.1.65:3000). En producción debe ser
# la URL pública de Render (ej https://servi-api.onrender.com).
# Lo consume MercadoPago como notification_url del webhook — si esto
# apunta a una IP local, MP nunca puede entregar webhooks en prod.
API_BASE_URL=http://localhost:3000

# URL pública del frontend web (Next.js en Vercel). MP redirige aquí
# tras success/failure/pending.
WEB_BASE_URL=https://www.oficioapp.org.pe

# CORS — coma-separadas. En prod listar solo tus dominios reales.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=                                   # openssl rand -hex 32
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=                           # openssl rand -hex 32 (DISTINTO al de access)
JWT_REFRESH_EXPIRES_IN=30d

# ── MercadoPago ────────────────────────────────────────────────
# Dashboard MP: https://www.mercadopago.com.pe/developers/panel/credentials
#
# - TEST-...: usar en development/staging (sandbox).
# - APP_USR-...: usar SOLO en producción.
# NUNCA mezclar: si NODE_ENV=production con TEST-... los pagos reales
# fallan; si NODE_ENV=development con APP_USR-... cobrás real a tarjetas
# de prueba.
MERCADOPAGO_ACCESS_TOKEN=TEST-...
MERCADOPAGO_PUBLIC_KEY=TEST-...

# Firma HMAC del webhook (Notificaciones webhook → Configurar firma).
# El backend rechaza TODOS los webhooks si esta clave es vacía,
# < 16 chars, o es el placeholder 'ningun_sistema'. Obligatoria en prod.
MERCADOPAGO_WEBHOOK_SECRET=

# ── Firebase Cloud Messaging ───────────────────────────────────
# Path al service-account JSON (NO commitear el JSON al repo).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── Email (Brevo / Sendinblue) ─────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=noreply@oficioapp.org.pe

# ── MinIO / S3 ─────────────────────────────────────────────────
MINIO_ENDPOINT=
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=servi-uploads

# ── Imágenes públicas (Opción A+C: CDN Cloudflare + thumbnails) ──
# Modo público de imágenes (perfil/ofertas/avatares). Se activa SOLO si AMBAS
# están definidas y MINIO_PUBLIC_BUCKET es DISTINTO de MINIO_BUCKET_NAME.
# Si faltan, todo se sirve firmado (X-Amz) como hoy — sin cambios.
#
# SEGURIDAD: el bucket público DEBE ser uno aparte. Las fotos de DNI/selfies
# (trust-validation) y vouchers de pago SIEMPRE van al bucket privado firmado,
# nunca al público. NO conectes el dominio Cloudflare al bucket privado.
#
# Pasos: 1) crear bucket R2 'oficio-public'  2) conectarle el Custom Domain
# (ej. img.oficioapp.org.pe, Proxied)  3) setear estas dos variables.
MINIO_PUBLIC_BUCKET=
MINIO_PUBLIC_URL=

# ── Redis (opcional, para WebSocket adapter) ────────────────────
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── Observabilidad (opcional) ──────────────────────────────────
SENTRY_DSN=
